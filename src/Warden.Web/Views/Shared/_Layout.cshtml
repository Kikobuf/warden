@inject CurrentUserService CurrentUser
@{
    var me = await CurrentUser.GetCurrentUserAsync();
    var perms = await CurrentUser.GetEffectivePermissionsAsync();
    bool Can(string key) => perms.Contains(key);
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Warden</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg warden-nav sticky-top">
        <div class="container-fluid px-3">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-lock-fill text-accent"></i> Warden
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navContent">
                @if (me is not null)
                {
                    <ul class="navbar-nav me-auto">
                        @if (Can(Permissions.DashboardView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                        }
                        @if (Can(Permissions.ServersView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Servers" asp-action="Index"><i class="bi bi-hdd-network"></i> Servers</a></li>
                        }
                        @if (Can(Permissions.ModerationView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Players" asp-action="Index"><i class="bi bi-people"></i> Players</a></li>
                        }
                        @if (Can(Permissions.PluginsView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Plugins" asp-action="Index"><i class="bi bi-puzzle"></i> Plugins</a></li>
                        }
                        @if (Can(Permissions.RolesManage))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Roles" asp-action="Index"><i class="bi bi-person-badge"></i> Roles</a></li>
                        }
                        @if (Can(Permissions.UsersManage))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index"><i class="bi bi-person-lines-fill"></i> Users</a></li>
                        }
                        @if (Can(Permissions.AuditLogView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="AuditLog" asp-action="Index"><i class="bi bi-journal-text"></i> Audit Log</a></li>
                        }
                    </ul>
                }
                <ul class="navbar-nav ms-auto">
                    @if (me is not null)
                    {
                        <li class="nav-item d-flex align-items-center text-secondary me-3">
                            @if (!string.IsNullOrEmpty(me.AvatarHash))
                            {
                                <img class="rounded-circle me-2" width="24" height="24"
                                     src="https://cdn.discordapp.com/avatars/@(me.DiscordUserId)/@(me.AvatarHash).png?size=32" alt="" />
                            }
                            <span>@me.Username</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Log out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-sm btn-accent" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-discord"></i> Sign in with Discord
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid px-3 py-4">
        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        @if (TempData["NewApiKey"] is string newKey)
        {
            <div class="alert alert-warning">
                <strong>New API key generated.</strong> Copy it now — it will not be shown again:
                <code class="d-block mt-2 fs-6 user-select-all">@newKey</code>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
