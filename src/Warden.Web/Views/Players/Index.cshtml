@model List<PlayerProfile>
@{
    ViewData["Title"] = "Players";
    string? q = ViewBag.Query;
}

<h1 class="page-title">Players</h1>

<form method="get" class="mb-3 d-flex gap-2" style="max-width: 480px;">
    <input type="text" name="q" value="@q" class="form-control" placeholder="Search by nickname or user ID…" />
    <button class="btn btn-accent">Search</button>
</form>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Nickname</th><th>User ID</th><th>First seen</th><th>Last seen</th></tr></thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-userId="@p.UserId">@p.LatestNickname</a></td>
                        <td class="text-secondary">@p.UserId</td>
                        <td>@p.FirstSeenAt.ToString("yyyy-MM-dd")</td>
                        <td>@p.LastSeenAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-secondary py-4">No players found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
