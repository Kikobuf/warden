@model List<AuditLogEntry>
@{
    ViewData["Title"] = "Audit log";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

<h1 class="page-title">Audit log</h1>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>When (UTC)</th><th>Actor</th><th>Action</th><th>Details</th></tr></thead>
            <tbody>
                @foreach (var entry in Model)
                {
                    <tr>
                        <td class="text-secondary text-nowrap">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@entry.Actor</td>
                        <td><code>@entry.Action</code></td>
                        <td>@entry.Details</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-secondary py-4">No entries yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
