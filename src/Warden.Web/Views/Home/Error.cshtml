@{
    ViewData["Title"] = "Error";
}

<div class="card p-4 text-center" style="max-width: 480px; margin: 4rem auto;">
    <i class="bi bi-exclamation-triangle fs-1 text-warning mb-3"></i>
    <h1 class="page-title">Something went wrong</h1>
    <p class="text-secondary">An unexpected error occurred. If this keeps happening, check the server logs.</p>
    <a class="btn btn-accent" asp-controller="Home" asp-action="Index">Back to dashboard</a>
</div>
