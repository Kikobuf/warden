@model Warden.Web.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="page-title">Dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card stat-card">
            <div class="stat-value">@Model.OnlineServers <span class="fs-6 text-secondary">/ @Model.TotalServers</span></div>
            <div class="stat-label">Servers online</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card stat-card">
            <div class="stat-value">@Model.TotalPlayersOnline</div>
            <div class="stat-label">Players online</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card stat-card">
            <div class="stat-value">@Model.ActiveBans</div>
            <div class="stat-label">Active bans</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card stat-card">
            <div class="stat-value">@Model.ActiveMutes</div>
            <div class="stat-label">Active mutes</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card stat-card">
            <div class="stat-value">@Model.TotalPlugins</div>
            <div class="stat-label">Plugins</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Recent activity</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr><th>When</th><th>Actor</th><th>Action</th><th>Details</th></tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.RecentAuditEntries)
                {
                    <tr>
                        <td class="text-secondary text-nowrap">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td>@entry.Actor</td>
                        <td><code>@entry.Action</code></td>
                        <td>@entry.Details</td>
                    </tr>
                }
                @if (!Model.RecentAuditEntries.Any())
                {
                    <tr><td colspan="4" class="text-secondary text-center py-4">No activity yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
