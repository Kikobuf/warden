@model List<WebRole>
@{
    ViewData["Title"] = "Roles";
    var groups = (IReadOnlyList<PermissionGroup>)ViewBag.PermissionGroups;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="page-title mb-0">Roles &amp; permissions</h1>
    <a class="btn btn-accent" asp-action="Create"><i class="bi bi-plus-lg"></i> New role</a>
</div>

@foreach (var role in Model)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h5 class="mb-0">@role.Name
                        @if (role.IsOwnerRole)
                        {
                            <span class="badge text-bg-success ms-1">Owner — all permissions</span>
                        }
                        @if (role.IsDefaultRole)
                        {
                            <span class="badge text-bg-secondary ms-1">Default — everyone has this</span>
                        }
                    </h5>
                    <p class="text-secondary small mb-0">@role.Description</p>
                </div>
                @if (!role.IsOwnerRole && !role.IsDefaultRole)
                {
                    <form method="post" asp-action="Delete" asp-route-id="@role.Id"
                          onsubmit="return confirm('Delete role &quot;@role.Name&quot;? Anyone holding only this role will lose its permissions.');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                }
            </div>

            @if (role.IsOwnerRole)
            {
                <p class="text-secondary small mb-0">This role always has every permission and can't be edited.</p>
            }
            else
            {
                <form method="post" asp-action="UpdatePermissions" asp-route-id="@role.Id">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        @foreach (var group in groups)
                        {
                            <div class="col-md-4">
                                <h6 class="text-secondary">@group.Name</h6>
                                @foreach (var perm in group.Permissions)
                                {
                                    var isChecked = role.Permissions.Any(p => p.PermissionKey == perm.Key);
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" name="permissionKeys" value="@perm.Key" id="@(role.Id)_@perm.Key" checked="@isChecked" />
                                        <label class="form-check-label small" for="@(role.Id)_@perm.Key">@perm.Description</label>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-light mt-3">Save permissions</button>
                </form>
            }
        </div>
    </div>
}
